model SubscriptionRequest {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @map("user_id") @db.Uuid
  groupId               String?  @map("group_id") @db.Uuid
  planId                String?  @map("plan_id") @db.Uuid
  amountPkr             Int      @default(0) @map("amount_pkr")
  currency              String   @default("PKR") @db.VarChar(10)
  paymentMethod         String?  @map("payment_method") @db.VarChar(40)
  screenshotKey         String?  @map("screenshot_key") @db.VarChar(512)
  note                  String?  @db.Text
  detailsSnapshot       Json?    @map("details_snapshot")
  status                String   @default("pending") @db.VarChar(20)
  adminNote             String?  @map("admin_note") @db.Text
  invoiceNo             String?  @unique @map("invoice_no") @db.VarChar(80)
  monthsAdded           Int      @default(1) @map("months_added")
  subscriptionStartDate DateTime? @map("subscription_start_date") @db.Date
  subscriptionEndDate   DateTime? @map("subscription_end_date") @db.Date
  approvedById          String?  @map("approved_by_id") @db.Uuid
  approvedAt            DateTime? @map("approved_at")
  rejectedAt            DateTime? @map("rejected_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  user                  User     @relation("SubscriptionRequester", fields: [userId], references: [id], onDelete: Cascade)
  group                 AccessGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  plan                  SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  approvedBy            User?    @relation("SubscriptionApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
  @@map("subscription_requests")
}

