  incidentLabel    String?  @map("incident_label") @db.VarChar(160)
  appArea          String?  @map("app_area") @db.VarChar(120)
  deviceModel      String?  @map("device_model") @db.VarChar(160)
  manufacturer     String?  @db.VarChar(120)
  androidVersion   String?  @map("android_version") @db.VarChar(60)
  appVersion       String?  @map("app_version") @db.VarChar(60)
  appVersionCode   Int?     @map("app_version_code")
