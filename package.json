{
  "name": "urdubolo-secure-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Security-first NestJS backend foundation for Urdu Bolo streaming",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathPattern=\\.spec\\.ts$",
    "test:integration": "jest --runInBand --testPathPattern=\\.integration-spec\\.ts$",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:validate": "prisma validate",
    "prisma:seed": "tsx prisma/seed.ts",
    "maintenance:cleanup": "tsx scripts/maintenance-cleanup.ts --apply",
    "legacy:migrate": "tsx scripts/legacy-migration/migrate.ts",
    "legacy:import-sql": "tsx scripts/legacy-migration/import-sql.ts",
    "legacy:verify": "tsx scripts/legacy-migration/verify.ts",
    "legacy:rollback": "tsx scripts/legacy-migration/rollback.ts",
    "load:test": "node scripts/load-test.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "argon2": "^0.43.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.19.3",
    "prom-client": "^15.1.3",
    "redis": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "mysql2": "^3.23.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
