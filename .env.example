NODE_ENV=development
PORT=3000
PUBLIC_API_ORIGIN=https://api.example.com
ADMIN_WEB_ORIGIN=https://admin.example.com
DATABASE_URL=postgresql://urdubolo:replace-me@localhost:5432/urdubolo?schema=public
POSTGRES_PASSWORD=replace-with-a-local-development-password
REDIS_URL=redis://localhost:6379
JWT_ISSUER=urdubolo-api
JWT_AUDIENCE=urdubolo-mobile
JWT_PRIVATE_KEY_B64=replace-with-base64-encoded-rsa-private-key
JWT_PUBLIC_KEY_B64=replace-with-base64-encoded-rsa-public-key
JWT_ACCESS_TTL_SECONDS=600
REFRESH_TOKEN_TTL_DAYS=30
TRUSTED_PROXY_HOPS=1
LOG_LEVEL=info
ENABLE_SWAGGER=false
METRICS_TOKEN=replace-with-at-least-32-random-bytes-for-prometheus
FIREBASE_SERVICE_ACCOUNT_B64=
ARGON2_DUMMY_HASH=replace-with-a-valid-argon2id-hash-for-timing-equalization
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=replace-with-a-strong-password
MEDIA_GATEWAY_PUBLIC_URL=https://api.example.com/media-gateway
MEDIA_LOCATOR_ENCRYPTION_KEY_B64=replace-with-base64-encoded-32-byte-key
MEDIA_PROVIDER_ALLOWED_HOSTS=storage.example.com
MEDIA_PROVIDER_ORIGIN_SECRET=replace-with-at-least-32-random-bytes
MEDIA_PROVIDER_TIMEOUT_MS=10000
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
PLAYBACK_CAPABILITY_TTL_SECONDS=120
MAX_CONCURRENT_PLAYBACK_SESSIONS=1
MAX_TRUSTED_DEVICES=3
